local luau = require("@lune/luau")
local Sandbox = require("./sandbox/build")

local Runner = {}

function Runner.execute(source: string): (boolean, string, string?)
	local env, state, codegen = Sandbox.build()

	codegen:emitLine(codegen:comment("Generated by Mimic V3"))
	codegen:emitLine("")

	local compiled = nil
	local compileSuccess, compileErr = pcall(function()
		compiled = luau.compile(source)
	end)

	if not compileSuccess or not compiled then
		codegen:emitLine(codegen:comment("Compilation failed: " .. tostring(compileErr)))
		return false, state:getOutput(), tostring(compileErr)
	end

	local loadSuccess, fnOrErr = pcall(function()
		return luau.load(compiled, {environment = env})
	end)

	if not loadSuccess then
		codegen:emitLine(codegen:comment("Load failed: " .. tostring(fnOrErr)))
		return false, state:getOutput(), tostring(fnOrErr)
	end

	local fn = fnOrErr

	if type(fn) ~= "function" then
		codegen:emitLine(codegen:comment("Load did not return a function"))
		return false, state:getOutput(), "Load did not return a function"
	end

	local execSuccess, execErr = pcall(fn)

	if not execSuccess then
		codegen:emitLine("")
		codegen:emitLine(codegen:comment("Execution halted: " .. tostring(execErr)))
	end

	return execSuccess, state:getOutput(), execSuccess and nil or tostring(execErr)
end

return Runner